# FitnessBattle - Environment Configuration

## Backend (.env)

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL=mysql://root:@localhost:3306/fitnessbattle

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d

# Security
CORS_ORIGIN=http://localhost:3000,exp://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=dev

# AI Coach
AI_MAX_CONTEXT_MESSAGES=20
AI_ENABLE_RAG=true
AI_RATE_LIMIT=30
