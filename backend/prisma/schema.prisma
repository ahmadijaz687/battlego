// ============================================
// COACHING
// ============================================

model CoachProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  bio             String?  @db.Text
  specialties     Json      @default("[]")
  certifications  Json      @default("[]")
  rating          Float    @default(0)
  sessionCount    Int      @default(0)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.DateTime(6)
  updatedAt       DateTime @updatedAt @db.DateTime(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients Client[] @relation("CoachClients")

  @@index([userId])
  @@map("coach_profiles")
}

model Client {
  id        String       @id @default(uuid())
  coachId   String
  clientId  String
  startDate DateTime     @default(now()) @db.DateTime(6)
  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @db.DateTime(6)

  coach  CoachProfile @relation("CoachClients", fields: [coachId], references: [id], onDelete: Cascade)
  client User         @relation("ClientCoach", fields: [clientId], references: [id], onDelete: Cascade)
  plans  ClientPlan[]

  @@unique([coachId, clientId])
  @@index([coachId])
  @@index([clientId])
  @@map("clients")
}

model ClientPlan {
  id          String   @id @default(uuid())
  clientId    String
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  startDate   DateTime @db.DateTime(6)
  endDate     DateTime? @db.DateTime(6)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.DateTime(6)
  updatedAt   DateTime @updatedAt @db.DateTime(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_plans")
}

