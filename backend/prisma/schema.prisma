  rewardType  String   @db.VarChar(100)
  rewardName  String   @db.VarChar(255)
  xp          Int      @default(0)
  coins       Int      @default(0)
  badgeId     String?
  titleId     String?
  image       String?  @db.VarChar(500)

  @@index([battleId])
  @@map("battle_rewards")
}

model BattleComment {
  id        String   @id @default(uuid())
  battleId  String
  userId    String
  message   String   @db.Text
  likes     Int      @default(0)
  createdAt DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  @@index([battleId])
  @@index([userId])
  @@map("battle_comments")
}

model BattleReaction {
  id        String   @id @default(uuid())
  battleId  String
  userId    String
  reaction  String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.DateTime(6)

  @@unique([battleId, userId])
  @@index([battleId])
  @@index([userId])
  @@map("battle_reactions")
}

// ============================================
// MISSING COLLECTIONS - Leaderboard
// ============================================

model Leaderboard {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(50)
  period     String?  @db.VarChar(50)
  seasonId   String?
  updatedAt  DateTime @updatedAt @db.DateTime(6)
  createdAt  DateTime @default(now()) @db.DateTime(6)

  entries LeaderboardEntry[]

  @@index([type, period])
  @@index([seasonId])
  @@map("leaderboards")
}

model LeaderboardEntry {
  id            String   @id @default(uuid())
  leaderboardId String
  userId        String
  rank          Int
  xp            Int      @default(0)
  points        Float    @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  streak        Int      @default(0)
  workouts      Int      @default(0)
  calories      Float    @default(0)
  distance      Float    @default(0)
  updatedAt     DateTime @updatedAt @db.DateTime(6)

  leaderboard Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, userId])
  @@index([leaderboardId, rank])
  @@index([userId])
  @@map("leaderboard_entries")
}

