generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique @db.VarChar(255)
  password      String    @db.VarChar(255)
  emailVerified Boolean   @default(false)
  name          String    @db.VarChar(255)
  avatar        String?   @db.VarChar(500)
  role          String    @default("user") @db.VarChar(50)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  points        Int       @default(0)
  timezone      String?   @db.VarChar(64)
  healthProviders Json?   @default("[]")
  createdAt     DateTime  @default(now()) @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @db.DateTime(6)

  // Relations
  refreshTokens RefreshToken[]
  workouts       Workout[]
  meals          Meal[]
  waterLogs      WaterLog[]
  weightLogs     WeightLog[]
  bodyMeasurements BodyMeasurement[]
  shoppingListItems ShoppingListItem[]
  posts          Post[]
  stories        Story[]
  friends        Friend[]
  friendRequestsSent   FriendRequest[] @relation("FriendRequestSender")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestReceiver")
  messages       Message[]
  conversations  ConversationMember[]
  communities    CommunityMember[]
  notifications  Notification[]
  aiConversations AIConversation[]
  userProfile    UserProfile?
  userAchievements UserAchievement[]
  userLevel      UserLevel?
  battlePasses   BattlePass[]
  challengeParticipants ChallengeParticipant[]
  habits         Habit[]
  sleepLogs      SleepLog[]
  hrvLogs        HRVLog[]
  moodLogs       MoodLog[]
  wearableData   WearableData[]
  comments       Comment[]
  postLikes      PostLike[]
  recoveryScores     RecoveryScore[]
  coachProfile       CoachProfile?
  clientOf           Client[]                 @relation("ClientCoach")
  programs           Program[]
  goals              Goal[]
  items              UserItem[]
  subscriptions      Subscription[]
  battlesAsCreator  Battle[]                 @relation("BattleCreator")
  battlesAsOpponent Battle[]                 @relation("BattleOpponent")
  battlesAsWinner   Battle[]                 @relation("BattleWinner")
  reportsMade        Report[]                 @relation("ReportReporter")
  reportsReceived    Report[]                 @relation("ReportReported")
  analyticsEvents    AnalyticsEvent[]
  devices            UserDevice[]
  syncRecords        SyncRecord[]
  settings           UserSettings?
  calendarEvents     CalendarEvent[]
  recoverySessions   RecoverySession[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  pushTokens         PushToken[]
  userBadges         UserBadge[]
  healthData         HealthData[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  familyId  String   @db.VarChar(36)
  revoked   Boolean  @default(false)
  expiresAt DateTime @db.DateTime(6)
  createdAt DateTime @default(now()) @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ============================================
// WORKOUTS
// ============================================

model Workout {
  id          String    @id @default(uuid())
  userId      String
  name        String    @db.VarChar(255)
  type        WorkoutType
  difficulty  Difficulty
  duration    Int
  startedAt   DateTime? @db.DateTime(6)
  completedAt DateTime? @db.DateTime(6)
  createdAt   DateTime  @default(now()) @db.DateTime(6)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections WorkoutSection[]

  @@index([userId])
  @@index([createdAt])
  @@map("workouts")
}

model WorkoutSection {
  id         String   @id @default(uuid())
  workoutId  String
  type       SectionType
  name       String   @db.VarChar(255)
  order      Int      @default(0)

  workout Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([workoutId])
  @@map("workout_sections")
}

model WorkoutExercise {
  id          String   @id @default(uuid())
  sectionId   String
  exerciseId  String   @db.VarChar(255)
  name        String   @db.VarChar(255)
  order       Int      @default(0)

  section WorkoutSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sets    WorkoutSet[]

  @@index([sectionId])
  @@map("workout_exercises")
}

model WorkoutSet {
  id            String   @id @default(uuid())
  exerciseId    String
  setNumber     Int
  reps          Int?
  weight        Float?
  duration      Int?
  distance      Float?
  tempo         String?  @db.VarChar(50)
  rpe           Int?
  restAfter     Int?
  notes         String?  @db.Text
  completed     Boolean  @default(false)
  isPR          Boolean  @default(false)
  completedAt   DateTime? @db.DateTime(6)

  exercise WorkoutExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("workout_sets")
}

model WorkoutTemplate {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  difficulty  Difficulty
  duration    Int
  exercises   Json
  createdAt   DateTime @default(now()) @db.DateTime(6)

  @@index([name])
  @@map("workout_templates")
}

model PersonalRecord {
  id           String    @id @default(uuid())
  userId       String
  exerciseId   String    @db.VarChar(255)
  exerciseName String    @db.VarChar(255)
  recordType   RecordType  @default(MAX_WEIGHT)
  value        Float
  unit         String    @db.VarChar(50)
  date         DateTime  @default(now()) @db.DateTime(6)

  @@unique([userId, exerciseId, recordType])
  @@index([userId])
  @@map("personal_records")
}

// ============================================
// NUTRITION
// ============================================

model Food {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  brand       String?  @db.VarChar(255)
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sugar       Float?
  servingSize String   @db.VarChar(100)
  category    String?  @db.VarChar(100)
  tags        Json     @default("[]")
  barcode     String?  @unique @db.VarChar(255)
  per100g     Json?
  createdAt   DateTime @default(now()) @db.DateTime(6)

  mealFoods MealFood[]

  @@index([name])
  @@index([category])
  @@map("foods")
}

model Meal {
  id        String   @id @default(uuid())
  userId    String
  name      String   @db.VarChar(255)
  type      MealType  @default(BREAKFAST)
  date      DateTime  @default(now())
  time      String?   @db.VarChar(8)
  createdAt DateTime @default(now()) @db.DateTime(6)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  foods  MealFood[]

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@index([date])
  @@map("meals")
}

model MealFood {
  id        String   @id @default(uuid())
  mealId    String
  foodId    String
  quantity  Float
  userId    String?  @db.VarChar(255)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  meal   Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food   Food  @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([mealId, foodId])
  @@index([userId])
  @@map("meal_foods")
}

model Recipe {
  id            String   @id @default(uuid())
  name          String   @unique @db.VarChar(255)
  description   String   @db.Text
  mealType      String   @db.VarChar(50)
  difficulty    String   @default("beginner") @db.VarChar(20)
  prepTime      Int
  cookTime      Int?
  servings      Int
  calories      Int
  protein       Float
  carbs         Float
  fat           Float
  fiber         Float?
  ingredients   Json     @default("[]")
  steps         Json     @default("[]")
  tags          Json     @default("[]")
  imageUrl      String?  @db.Text
  createdAt     DateTime @default(now()) @db.DateTime(6)
  updatedAt     DateTime @updatedAt @db.DateTime(6)

  @@index([mealType])
  @@index([name])
  @@map("recipes")
}

model WaterLog {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  date      DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("water_logs")
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  date      String   @db.VarChar(50)
  weight    Float
  unit      WeightUnit

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("weight_logs")
}

model BodyMeasurement {
  id        String   @id @default(uuid())
  userId    String
  date      String   @db.VarChar(50)
  chest     Float?
  waist      Float?
  hips       Float?
  shoulders  Float?
  arms       Float?
  forearms   Float?
  thighs     Float?
  calves     Float?
  neck       Float?
  bodyFat    Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("body_measurements")
}

model ShoppingListItem {
  id             String   @id @default(uuid())
  userId         String
  shoppingListId String?
  name           String   @db.VarChar(255)
  quantity       Float
  unit           String   @db.VarChar(50)
  category       String   @db.VarChar(100)
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.DateTime(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingList ShoppingList? @relation(fields: [shoppingListId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([shoppingListId])
  @@map("shopping_list_items")
}

// ============================================
// SOCIAL
// ============================================

model Post {
  id        String   @id @default(uuid())
  userId    String
  userName  String   @db.VarChar(255)
  userAvatar String? @db.VarChar(500)
  content   String   @db.Text
  images    Json?    // Array of image URLs
  workoutId String?
  mealId    String?
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  saves     Int      @default(0)
  type      PostType
  createdAt DateTime @default(now()) @db.DateTime(6)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  postComments Comment[] @relation("PostComments")
  postLikes    PostLike[] @relation("PostLikes")

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  userName  String   @db.VarChar(255)
  image     String?  @db.VarChar(500)
  videoUrl  String?  @db.VarChar(500)
  viewed    Boolean  @default(false)
  duration  Int
  expiresAt DateTime @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("stories")
}

model Friend {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  name      String   @db.VarChar(255)
  username  String   @unique @db.VarChar(255)
  avatar    String?  @db.VarChar(500)
  status    FriendStatus
  lastSeen  DateTime? @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@map("friends")
}

model FriendRequest {
  id           String   @id @default(uuid())
  userId       String
  fromUserId   String
  fromUserName String   @db.VarChar(255)
  fromUserAvatar String? @db.VarChar(500)
  status       FriendRequestStatus
  createdAt    DateTime @default(now()) @db.DateTime(6)

  sender   User @relation("FriendRequestSender", fields: [userId], references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceiver", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@unique([userId, fromUserId])
  @@index([userId, status])
  @@map("friend_requests")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  senderName     String   @db.VarChar(255)
  content        String   @db.Text
  mediaUrl       String?  @db.VarChar(500)
  sentAt         DateTime @default(now()) @db.DateTime(6)
  readAt         DateTime? @db.DateTime(6)
  deliveredAt    DateTime? @db.DateTime(6)
  type           MessageType

  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@map("messages")
}

model Conversation {
  id              String   @id @default(uuid())
  participantIds  Json     // Array of user IDs
  participantNames Json    // Array of user names
  lastMessage     String?  @db.Text
  lastMessageAt   DateTime? @db.DateTime(6)
  unreadCount     Int      @default(0)
  createdAt       DateTime @default(now()) @db.DateTime(6)

  members  ConversationMember[]
  messages Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  userName       String   @db.VarChar(255)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Community {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String   @db.Text
  avatar      String?  @db.VarChar(500)
  memberCount Int      @default(0)
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.DateTime(6)

  members CommunityMember[]

  @@index([name])
  @@map("communities")
}

model CommunityMember {
  id         String   @id @default(uuid())
  communityId String
  userId     String
  userName   String   @db.VarChar(255)
  joinedAt   DateTime @default(now()) @db.DateTime(6)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("community_members")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      NotificationType
  title     String   @db.VarChar(255)
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.DateTime(6)
  relatedId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// AI
// ============================================

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @db.VarChar(255)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String   @db.Text
  thinking       Boolean  @default(false)
  timestamp      DateTime @default(now()) @db.DateTime(6)

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("ai_messages")
}

// ============================================
// KNOWLEDGE BASE
// ============================================

model KnowledgeArticle {
  id              String   @id @default(uuid())
  title           String   @db.VarChar(500)
  category        String   @db.VarChar(100)
  summary         String   @db.Text
  content         String   @db.Text
  tags            Json     @default("[]")
  difficulty      String   @default("beginner") @db.VarChar(20)
  evidenceLevel   String?  @db.VarChar(50)
  relatedTopics   Json     @default("[]")
  references      Json     @default("[]")
  createdAt       DateTime @default(now()) @db.DateTime(6)
  updatedAt       DateTime @updatedAt @db.DateTime(6)

  @@index([category])
  @@index([title])
  @@map("knowledge_articles")
}

// ============================================
// EXERCISES
// ============================================

model Exercise {
  id              String   @id @default(uuid())
  name            String   @unique @db.VarChar(200)
  primaryMuscle   String   @db.VarChar(100)
  secondaryMuscles Json     @default("[]")
  equipment       Json     @default("[]")
  difficulty      String   @default("beginner") @db.VarChar(50)
  category        String?  @db.VarChar(100)
  tags            Json     @default("[]")
  instructions    String?  @db.Text
  imageUrl        String?  @db.Text
  videoUrl        String?  @db.Text
  met             Float?   @db.Double
  isBodyweight    Boolean  @default(false)
  caloriesPerMin  Float?   @db.Double
  demoMedia       Json?    @default("[]")
  createdAt       DateTime @default(now()) @db.DateTime(6)
  updatedAt       DateTime @updatedAt @db.DateTime(6)

  programExercises ProgramExercise[]

  @@index([primaryMuscle])
  @@index([difficulty])
  @@index([category])
  @@index([isBodyweight])
  @@map("exercises")
}

// ============================================
// BATTLES
// ============================================

model Battle {
  id            String       @id @default(uuid())
  creatorId     String
  opponentId    String?
  type          String       @db.VarChar(100)
  battleTypeId  String?
  battleType    BattleType?  @relation(fields: [battleTypeId], references: [id], onDelete: SetNull)
  mode          BattleMode?
  metric        String?
  target        Float?
  inviteCode    String?      @unique @db.VarChar(50)
  status        BattleStatus
  creatorScore  Float?
  opponentScore Float?
  startTime     DateTime?    @db.DateTime(6)
  endTime       DateTime?    @db.DateTime(6)
  winnerId      String?
  createdAt     DateTime     @default(now()) @db.DateTime(6)
  updatedAt     DateTime     @updatedAt @db.DateTime(6)

  creator  User  @relation("BattleCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  opponent User? @relation("BattleOpponent", fields: [opponentId], references: [id], onDelete: SetNull)
  winner   User? @relation("BattleWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([opponentId])
  @@index([winnerId])
  @@index([status])
  @@index([inviteCode])
  @@index([createdAt])
  @@map("battles")
}

// ============================================
// USER PROFILE
// ============================================

model UserProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?   @db.Text
  dateOfBirth   DateTime? @db.DateTime(6)
  height        Float?
  heightUnit    String    @default("cm") @db.VarChar(10)
  goal          String?   @db.VarChar(255)
  experience    String    @default("beginner") @db.VarChar(50)
  fitnessLevel  String    @default("beginner") @db.VarChar(50)
  activityLevel String    @default("sedentary") @db.VarChar(50)
  equipment     Json      @default("[]")
  injuries      Json      @default("[]")
  preferences   Json      @default("{}")
  onboardingComplete Boolean @default(false)
  createdAt     DateTime  @default(now()) @db.DateTime(6)
  updatedAt     DateTime  @updatedAt @db.DateTime(6)

  @@index([userId])
  @@map("user_profiles")
}

// ============================================
// ACHIEVEMENTS & GAMIFICATION
// ============================================

model Achievement {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(255)
  description String   @db.Text
  icon        String   @db.VarChar(500)
  category    String   @db.VarChar(100)
  xpReward    Int      @default(0)
  criteria    Json     @default("{}")
  createdAt   DateTime @default(now()) @db.DateTime(6)

  userAchievements UserAchievement[]

  @@index([category])
  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now()) @db.DateTime(6)

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserLevel {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     Int      @default(1)
  xp        Int      @default(0)
  totalXp   Int      @default(0)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  @@index([userId])
  @@map("user_levels")
}

// ============================================
// BATTLE PASS & SEASONS
// ============================================

model Season {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  startDate   DateTime @db.DateTime(6)
  endDate     DateTime @db.DateTime(6)
  active      Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.DateTime(6)

  battlePasses BattlePass[]

  @@index([active])
  @@map("seasons")
}

model BattlePass {
  id        String   @id @default(uuid())
  userId    String
  seasonId  String
  tier      Int      @default(1)
  xp        Int      @default(0)
  premium   Boolean  @default(false)
  claimed   Json     @default("[]")
  createdAt DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([userId])
  @@index([seasonId])
  @@map("battle_passes")
}

// ============================================
// HABIT TRACKING
// ============================================

model Habit {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  frequency   String   @default("daily") @db.VarChar(50)
  target      Int      @default(1)
  unit        String?  @db.VarChar(50)
  streak      Int      @default(0)
  longestStreak Int    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.DateTime(6)
  updatedAt   DateTime @updatedAt @db.DateTime(6)

  logs HabitLog[]

  @@index([userId, active])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime @db.DateTime(6)
  value     Float    @default(1)
  note      String?  @db.Text
  createdAt DateTime @default(now()) @db.DateTime(6)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@map("habit_logs")
}

// ============================================
// HEALTH METRICS
// ============================================

model SleepLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.DateTime(6)
  duration   Int
  quality    Int?
  deepSleep  Int?
  remSleep   Int?
  lightSleep Int?
