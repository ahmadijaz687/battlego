// ============================================

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @db.DateTime(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @db.DateTime(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("email_verification_tokens")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.DateTime(6)
  updatedAt DateTime @updatedAt @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("push_tokens")
}

// ============================================
// BADGES
// ============================================

model Badge {
  id         String   @id @default(uuid())
  key        String   @unique @db.VarChar(100)
  name       String   @db.VarChar(255)
  description String? @db.Text
  icon       String?  @db.VarChar(500)
  tier       String   @default("common") @db.VarChar(50)
  xpReward   Int      @default(0)

  userBadges UserBadge[]

  @@index([key])
  @@index([tier])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now()) @db.DateTime(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

// ============================================
// HEALTH DATA (wearable sync)
// ============================================

model HealthData {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source     String   @db.VarChar(50)
  metric     String   @db.VarChar(100)
  value      Float
  unit       String?  @db.VarChar(50)
  recordedAt DateTime @default(now()) @db.DateTime(6)
  createdAt  DateTime @default(now()) @db.DateTime(6)

  @@index([userId, metric])
  @@index([userId, recordedAt])
  @@map("health_data")
}