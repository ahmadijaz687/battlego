  @@index([missionDate])
  @@map("daily_missions")
}

model WeeklyMission {
  id            String   @id @default(uuid())
  userId        String
  week          Int
  year          Int
  missions      Json     @default("[]")
  completed     Boolean  @default(false)
  rewardClaimed Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.DateTime(6)

  @@unique([userId, week, year])
  @@index([userId])
  @@map("weekly_missions")
}

model MonthlyMission {
  id            String   @id @default(uuid())
  userId        String
  month         Int
  year          Int
  missions      Json     @default("[]")
  completed     Boolean  @default(false)
  rewardClaimed Boolean  @default(false)
