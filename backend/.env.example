# ============================================================================
# FitnessBattle Backend — Environment Configuration
# Copy to `.env` and adjust. All values are injected externally in Docker/EAS/CI.
# ============================================================================

# --- Server ---
PORT=5000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=dev
LOG_FORMAT=combined

# --- Database (MySQL via Prisma) ---
DATABASE_URL=mysql://root:@localhost:3306/fitnessbattle

# --- Redis (optional; falls back to in-memory cache) ---
REDIS_URL=redis://localhost:6379

# --- Auth / Sessions ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d
SESSION_SECRET=change-me-session-secret

# --- CORS (comma-separated explicit origins; never use "*" in production) ---
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- AI Coach (rule-based by default; set a key to enable LLM) ---
AI_PROVIDER=openai
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
AI_MAX_CONTEXT_MESSAGES=20
AI_ENABLE_RAG=true
AI_RATE_LIMIT=30

# --- Sentry (optional - leave empty to disable) ---
SENTRY_DSN=

# --- Client ---
API_URL=http://localhost:5000