{
  "name": "fitnessbattle-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx ./src/index.ts",
    "dev": "node --import tsx --watch ./src/index.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:ai": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit tests/ai.test.ts",
    "test:validation": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit tests/validation.test.ts",
    "docker:test": "docker compose -f docker-compose.test.yml up --abort-on-container-exit --exit-code-from test",
    "verify": "tsx scripts/verify.ts",
    "verify:seed": "tsx scripts/seed-verify.ts",
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.0.0",
    "@types/nodemailer": "^8.0.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "connect-redis": "^8.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "nanoid": "^5.0.7",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
